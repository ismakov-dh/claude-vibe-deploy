# Auto-generated by vibe-deploy. Do not edit manually.
# App: {{.Name}} | Type: {{.AppType}} | Generated: {{.Timestamp}}

services:
  {{.Name}}:
    build:
      context: ./src
      dockerfile: Dockerfile.vd
    container_name: vd-{{.Name}}
    restart: unless-stopped
{{- if .HasEnvFile}}
    env_file:
      - ./src/.env
{{- end}}
    labels:
      - "vd.app={{.Name}}"
      - "vd.port={{.Port}}"
      - "traefik.enable=true"
{{- if eq .Routing "subdomain"}}
      - "traefik.http.routers.vd-{{.Name}}.rule=Host(`{{.Name}}.{{.Domain}}`)"
{{- else}}
      - "traefik.http.routers.vd-{{.Name}}.rule=PathPrefix(`/{{.Name}}`)"
      - "traefik.http.middlewares.vd-{{.Name}}-strip.stripprefix.prefixes=/{{.Name}}"
      - "traefik.http.routers.vd-{{.Name}}.middlewares=vd-{{.Name}}-strip"
{{- end}}
      - "traefik.http.services.vd-{{.Name}}.loadbalancer.server.port={{.Port}}"
      - "traefik.http.routers.vd-{{.Name}}.entrypoints=web"
    networks:
      - vd-net
{{- if .NeedsDB}}
      - vd-db
{{- end}}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:{{.Port}}/"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s

networks:
  vd-net:
    external: true
{{- if .NeedsDB}}
  vd-db:
    external: true
{{- end}}
